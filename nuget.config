<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- local-packages/ populated by CI before restore — allows referencing Pagmo.NET without NuGet.org publish -->
    <add key="local-build" value="local-packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
